# =============================================================================
# .env.example — Plantilla de variables de entorno para SAITO
# =============================================================================
# Copia este archivo como `.env` (NO se versiona) y rellena los valores reales.
#
# IMPORTANTE — Reglas de seguridad:
#   - Las variables con prefijo VITE_* se inyectan en el bundle del navegador
#     y son PÚBLICAS. Cualquiera puede leerlas en DevTools.
#   - NUNCA pongas una service role key (ni cualquier secreto del servidor)
#     en una variable VITE_*. Solo claves "publishable / anon" son aceptables.
#   - En Lovable, las variables se configuran desde el panel de entorno
#     (Lovable Cloud → Settings / Workspace → Build Secrets), no editando
#     este archivo en el repo. Este `.env.example` solo documenta los nombres.
# =============================================================================


# ---------- Modo demo / UI -----------------------------------------------------
# Activa el banner "Datos de demostración" y datos seed cuando no hay backend.
VITE_DEMO_MODE=true

# Muestra junto a títulos de pantalla un badge indicando el origen
# (datos demo vs datos reales del backend).
VITE_SHOW_DATA_SOURCE_BADGE=true

# Activa el password gate global del sitio (PasswordGate.tsx).
# Útil para demos cerradas. En producción real debe ser false.
VITE_ENABLE_PASSWORD_GATE=false

# Contraseña del password gate cuando VITE_ENABLE_PASSWORD_GATE=true.
# OJO: viaja al cliente, NO es seguridad real, solo gating de demo.
VITE_DEMO_PASSWORD=


# ---------- Lovable Cloud (Supabase) — cliente / browser ---------------------
# Estas tres son PÚBLICAS por diseño (anon/publishable key).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=


# ---------- Lovable Cloud (Supabase) — server / edge functions ---------------
# Usadas en supabase/functions/* y server functions de TanStack Start.
# NUNCA expongas SUPABASE_SERVICE_ROLE_KEY en el cliente.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ---------- IA / proveedores externos ----------------------------------------
# Si se usa la pasarela de Lovable AI no hace falta OPENAI_API_KEY.
# Mantenida aquí por si en el futuro se conecta OpenAI directamente.
OPENAI_API_KEY=

# Clave gestionada de la pasarela de Lovable AI (la inyecta Lovable Cloud).
# No la rellenes manualmente; aparece como secreto en Lovable.
LOVABLE_API_KEY=
